# LocalChat only listens on this computer by default.
LOCALCHAT_HOST=127.0.0.1
LOCALCHAT_PORT=8000
LOCALCHAT_ENVIRONMENT=production
LOCALCHAT_OPEN_BROWSER=false

# Model runtime
LOCALCHAT_MODELS_DIR=./models
# LOCALCHAT_DEFAULT_MODEL=your-model.gguf
LOCALCHAT_CONTEXT_SIZE=4096
LOCALCHAT_THREADS=8
LOCALCHAT_GPU_LAYERS=0
LOCALCHAT_BATCH_SIZE=512
# LOCALCHAT_CHAT_FORMAT=

# Development web origins, comma-separated
LOCALCHAT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
